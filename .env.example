# Anthropic API key (used by the Anthropic SDK)
ANTHROPIC_API_KEY=sk-....

# Anthropic base URL — required when routing through a proxy
ANTHROPIC_BASE_URL=https://licenseportal.aiengineeringlab.co.uk

# LiteLLM proxy base URL (no trailing slash)
LITELLM_BASE_URL=https://licenseportal.aiengineeringlab.co.uk

# LiteLLM master key or API key with spend-read permissions
LITELLM_API_KEY=sk-....

# Claude model name — must match the model ID registered on the proxy
# Run GET /v1/models against the proxy to see available options
ANTHROPIC_MODEL=eu.anthropic.claude-sonnet-4-6

# Optional: default output format for reports (table | json | markdown)
REPORT_FORMAT=table
